function doPost(e) {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheets()[0];
  var data = JSON.parse(e.postData.contents);

  // --- Configuration ---
  var voteMap = {
    "HATE": 3,     // Column C
    "DISLIKE": 4,  // Column D
    "NEUTRAL": 5,  // Column E
    "LIKE": 6,     // Column F
    "LOVE": 7      // Column G
  };
  
  var timestampColumnIndex = 2; // Column B is index 2
  var startRow = 2;             // Start searching from the second row (assuming row 1 is headers)
  
  // --- Data from Payload ---
  // TRIM the incoming string to remove any hidden whitespace
  var incomingTimestamp = String(data.timestamp).trim(); 
  var incomingVote = data.vote; 
  var targetColumn = voteMap[incomingVote];

  Logger.log("Incoming Payload Data: Timestamp=" + incomingTimestamp + ", Vote=" + incomingVote);
  
  if (!targetColumn) {
    return ContentService.createTextOutput("Error: Invalid vote type received: " + incomingVote);
  }

  // 1. Find the row with the matching timestamp
  var lastRow = sheet.getLastRow();
  var isRowUpdated = false;

  if (lastRow >= startRow) {
    var timestampsRange = sheet.getRange(startRow, timestampColumnIndex, lastRow - startRow + 1, 1);
    var timestamps = timestampsRange.getValues();

    for (var i = 0; i < timestamps.length; i++) {
      var sheetValue = timestamps[i][0];
      var sheetTimestampString = '';

      // --- CRITICAL TIMESTAMP COMPARISON LOGIC ---

        // If it's not a Date (e.g., plain text), convert to string and TRIM for safety
        sheetTimestampString = String(sheetValue).trim();
        
      // Compare the formatted sheet string with the incoming payload string
      Logger.log("Row " + (i + startRow) + ": Comparing Sheet value: '" + sheetTimestampString + "' to Incoming value: '" + incomingTimestamp + "'");
      var logCell = sheet.getRange("H1");
      logCell.setValue("Row " + (i + startRow) + ": Comparing Sheet value: '" + sheetTimestampString + "' to Incoming value: '" + incomingTimestamp + "'")



      if (sheetTimestampString === incomingTimestamp) {
        var rowToUpdate = i + startRow; 
        
        // 2. Update the vote count
        var targetCell = sheet.getRange(rowToUpdate, targetColumn);
        var currentCount = targetCell.getValue();
        
        // Increment count, defaulting to 1 if the cell is empty or non-numeric
        var newCount = (typeof currentCount === 'number' && !isNaN(currentCount)) ? currentCount + 1 : 1;

        targetCell.setValue(newCount);

        isRowUpdated = true;
        Logger.log("SUCCESS: Row " + rowToUpdate + " updated in column " + targetColumn);
        break; // Exit the loop once the row is found and updated
      }
    }
  }

  // 3. Fallback: If no matching row was found, append a new row
  if (!isRowUpdated) {
     var newRowVotes = [0, 0, 0, 0, 0]; 
     newRowVotes[targetColumn - 3] = 1; 
     
     // The columns appended are: Date, Timestamp, HATE, DISLIKE, NEUTRAL, LIKE, LOVE
     sheet.appendRow([new Date(), incomingTimestamp].concat(newRowVotes));
     Logger.log("APPENDED: No matching row found. Appended new row for timestamp: " + incomingTimestamp);
     return ContentService.createTextOutput("Data appended as no existing row was found");
  } 

  return ContentService.createTextOutput("Vote incremented successfully");
}

function doGet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheets()[0];
  
  // --- CONFIGURATION ---
  // This format MUST match the plain text in your sheet exactly.
  // Examples: "yyyy-MM-dd", "MM/dd/yyyy", "dd/MM/yyyy"
  const dateFormat = "yyyy-MM-dd"; 
  const timeZone = ss.getSpreadsheetTimeZone();
  
  // Generate "Today" as a string in that specific format
  const todayStr = Utilities.formatDate(new Date(), timeZone, dateFormat);
  
  // --- LOGIC ---
  // 1. Get all text from Column B
  // Since it's plain text, getValues() returns strings, not Date objects.
  const colBValues = sheet.getRange("B:B").getValues();
  
  let targetRow = 0;
  
  // 2. Loop to find the match
  for (let i = 0; i < colBValues.length; i++) {
    // Compare string to string. 
    // We use String() and trim() to remove accidental spaces and ensure type safety.
    if (String(colBValues[i][0]).trim() === todayStr) {
      targetRow = i + 1; // Found the row (1-indexed)
      break; 
    }
  }

  // 3. If no match found
  if (targetRow === 0) {
    return ContentService.createTextOutput(JSON.stringify({
      "status": "error", "message": "No row found for date: " + todayStr
    })).setMimeType(ContentService.MimeType.JSON);
  }

  // 4. Return Data (Columns A-G)
  // We use getDisplayValues() to ensure the microcontroller gets exactly what you see
  const rowData = sheet.getRange(targetRow, 1, 1, 7).getDisplayValues()[0];

  const result = {
    "row": targetRow,
    "data": rowData
  };

  return ContentService.createTextOutput(JSON.stringify(result))
    .setMimeType(ContentService.MimeType.JSON);
}

function updateChart() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheets()[0];
  
  // --- 1. Find the last row with data in Cols C-G ---
  const lastRow = sheet.getLastRow();
  const rawData = sheet.getRange(2, 3, lastRow - 1, 5).getValues();
  
  let trueLastRow = 0;
  for (let i = rawData.length - 1; i >= 0; i--) {
    if (rawData[i].some(cell => cell !== "" && cell !== null)) {
      trueLastRow = i + 2; 
      break;
    }
  }
  if (trueLastRow === 0) return;

  // --- 2. Define the Window (Last 5 Rows) ---
  const numRowsToDisplay = 5;
  const startRow = Math.max(2, trueLastRow - numRowsToDisplay + 1);
  const rowsToGrab = (trueLastRow - startRow + 1);

  // --- 3. Clear Old Charts ---
  const charts = sheet.getCharts();
  for (let i = 0; i < charts.length; i++) {
    sheet.removeChart(charts[i]);
  }

  // --- 4. Get Headers from Row 1 (Columns C-G) ---
  // We read the 1st row, columns 3 to 7 (C, D, E, F, G)
  const headers = sheet.getRange(1, 3, 1, 5).getValues()[0];

  // --- 5. Build Series Options ---
  // We create an object that tells the chart: "Series 0 is named 'Temp', Series 1 is 'Humidity'..."
  const seriesOptions = {};
  for (let i = 0; i < headers.length; i++) {
    seriesOptions[i] = { labelInLegend: headers[i] }; // Map index to header name
  }

  // --- 6. Define Ranges ---
  const labelRange = sheet.getRange(startRow, 1, rowsToGrab, 1); // Col A (X-Axis)
  const dataRange = sheet.getRange(startRow, 3, rowsToGrab, 5);  // Col C-G (Data)

  // --- 7. Build the Bar Chart ---
  const chart = sheet.newChart()
    .setChartType(Charts.ChartType.COLUMN)
    .addRange(labelRange)
    .addRange(dataRange)
    .setPosition(2, 9, 0, 0)
    .setOption('title', 'Sensor Data (Last 5 Entries)')
    .setOption('legend', {position: 'right'}) // Move legend to right for better visibility
    // Apply our custom headers here
    .setOption('series', seriesOptions) 
    .build();

  sheet.insertChart(chart);
}
